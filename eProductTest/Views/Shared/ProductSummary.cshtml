@model Product

<div class="card border-dark-subtle m-1 p-1">
    <div class="bg-light p-1">
        <h4>
            @Model?.Name
            <span class="badge rounded-pill bg-primary text-white" style="float:right">
                <small>@Model?.Price.ToString("c")</small>
            </span>
        </h4>
    </div>
@*     <div class="card-text p-1">@Model?.Description</div>
    <div class="card-text p-1">[@Model?.Category]</div> *@

    <form id="@Model?.ProductID" asp-page="/Cart" method="post">
        <input type="hidden" asp-for="ProductID" />
        <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
        <span class="card-text p-1">
            @Model?.Description/[Model.Category]
            <button type="submit" class="btn btn-success btn-sm float-end" style="float:right">
                Add to Cart
            </button>
        </span>
    </form>
</div>